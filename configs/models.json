  "jobs": {
    "translate_korean_lookup": {
      "script": "scripts/translation/translate_korean_with_lookup.py",
      "description": "EN->KO procedure translation with Qdrant bilingual pair lookup + style guide",
      "default_model": "gemma4-26b",
      "concurrency": 16,
      "eval_set": "data/evals/korean/procedure_eval_set.csv",
      "output_dir": "data/evals/korean",
      "qdrant_collection": "paired_translations_ko",
      "lookup_topn": 5,
      "style_guide": "style_guide/style_guide_ko.md",
      "llm_params": {
        "max_tokens": 256,
        "temperature": 0.0,
        "stop": [
          "\n\n",
          "English:"
        ],
        "chat_template_kwargs": {
          "enable_thinking": false
        },
        "enable_thinking": false
      }
    },
    "translate_korean_baseline": {
      "script": "scripts/translation/translate_korean_sample.py",
      "description": "EN->KO baseline translation (no lookup, optional style guide)",
      "default_model": "gemma4-26b",
      "concurrency": 16,
      "eval_set": "data/evals/korean/procedure_eval_sample_100.csv",
      "output_dir": "data/evals/korean",
      "style_guide": "style_guide/style_guide_ko.md",
      "llm_params": {
        "max_tokens": 128,
        "temperature": 0.0,
        "stop": [
          "\n\n",
          "English:"
        ]
      }
    },
    "score_korean": {
      "script": "scripts/evaluation/score_korean_translations.py",
      "description": "Score translations against KR extension reference (char_sim, token_jaccard, exact)"
    },
    "judge_korean": {
      "script": "scripts/evaluation/judge_korean_translations.py",
      "description": "LLM-as-judge: classify non-matching translations as ACCEPTABLE / PARTIAL / WRONG",
      "default_model": "gemma4-26b",
      "concurrency": 16,
      "labels": [
        "ACCEPTABLE",
        "PARTIAL",
        "WRONG"
      ],
      "llm_params": {
        "max_tokens": 256,
        "temperature": 0.0,
        "chat_template_kwargs": {
          "enable_thinking": false
        }
      },
      "notes": "For Qwen3 reasoning models, disable thinking — otherwise the model burns all tokens on reasoning and returns null content."
    }
  }
}