{
  "id": "snomed-bt-rerank",
  "name": "snomed-bt-rerank",
  "description": "Back-translate KO->EN, then cross-encoder rerank top-10 (recall@K after rerank).",
  "nodes": [
    {
      "id": "gold",
      "type": "datasource",
