{
  "version": 1,
  "name": "snomed_backtrans_hierarchy_coherence_v1",
  "description": "Exploit the SNOMED is-a hierarchy as a confidence signal: are the top-K retrieved concepts ontologically CLUSTERED (deep common ancestor) or SCATTERED? Test whether hierarchical coherence of the candidate set predicts a correct match better than the embedding cosine/margin (which top out at ~82% precision / AUC 0.74).",
  "environment": {
    "version": 1,
    "name": "project",
    "description": "",
    "language": {
      "code": "ko",
      "name": "Korean",
      "direction": "EN->KO",
      "tokenizer_lang": "en"
    },
    "paths": {
      "root": ".",
      "data_dir": "data",
      "output_dir": "data/evals/korean",
      "lookup_cache": "data/evals/korean/lookup_cache.json"
    },
    "qdrant": {
      "url": "http://localhost:6333",
      "bgem3": {
        "model_name": "BAAI/bge-m3",
        "use_fp16": false,
        "batch_size": 256,
        "max_length": 512
      }
    },
    "overlap_defaults": {
      "prompt_addendum": "additive",
      "term_dictionary": "most_specific",
      "retrieval_corpus": "additive",
      "exemplar_set": "union_dedupe"
    },
    "default_model_key": "gemma4-26b"
  },
  "problem": "back-translation-confidence-round-trip-snomed-linkage"
}